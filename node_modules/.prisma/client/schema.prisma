// This is your Prisma schema file for SQLite
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  password               String
  name                   String
  bio                    String?
  avatar                 String?
  photos                 String?
  videoUrl               String?
  isVerified             Boolean   @default(false)
  verificationPhotoUrl   String?
  introVideoUrl          String?
  hasClaimedProfileBonus Boolean   @default(false)
  isPaused               Boolean   @default(false)
  pausedUntil            DateTime?
  lastActivityDate       DateTime?
  profileCompleted       Boolean   @default(false)
  age                    Int?
  gender                 String?
  location               String?
  country                String?
  state                  String?
  city                   String?
  showAllCountries       Boolean   @default(false)
  selectedCountries      String?
  lookingFor             String?
  points                 Int       @default(0)
  tier                   String    @default("free")
  trialTier              String?
  trialExpiresAt         DateTime?
  likesUsedToday         Int       @default(0)
  lastLikeResetDate      DateTime?
  passesUsedToday        Int       @default(0)
  lastPassResetDate      DateTime?
  messagesUsedToday      Int       @default(0)
  lastMessageResetDate   DateTime?
  isAdmin                Boolean   @default(false)
  lastSignInDate         DateTime?
  weeklySignInCount      Int       @default(0)
  weeklySignInResetDate  DateTime?
  lastAdCompletedAt      DateTime?
  adCompletionsToday     Int       @default(0)
  adCompletionsResetDate DateTime?
  fraudScore             Int       @default(0)
  isFlagged              Boolean   @default(false)
  botIgnoredByAdmin      Boolean   @default(false)
  referralCode           String?   @unique
  referredById           String?
  referredBy             User?     @relation("referrals", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals              User[]    @relation("referrals")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  pointsTransactions                PointsTransaction[]
  adViews                           AdView[]
  surveyResponses                   SurveyResponse[]
  sentMessages                      Message[]                          @relation("sender")
  receivedMessages                  Message[]                          @relation("receiver")
  likes                             Like[]                             @relation("liker")
  likedBy                           Like[]                             @relation("liked")
  matches                           Match[]                            @relation("userMatches")
  matchedWith                       Match[]                            @relation("matchedWithUser")
  blockedUsers                      BlockedUser[]                      @relation("blocker")
  blockedBy                         BlockedUser[]                      @relation("blocked")
  questionnaire                     Questionnaire?
  personalityQuestionnaire          PersonalityQuestionnaire?          @relation("personalityQuestionnaire")
  relationshipGoalsQuestionnaire    RelationshipGoalsQuestionnaire?    @relation("relationshipGoalsQuestionnaire")
  lifestyleQuestionnaire            LifestyleQuestionnaire?            @relation("lifestyleQuestionnaire")
  valuesBelifsQuestionnaire         ValuesBelifsQuestionnaire?         @relation("valuesBelifsQuestionnaire")
  interestsHobbiesQuestionnaire     InterestsHobbiesQuestionnaire?     @relation("interestsHobbiesQuestionnaire")
  musicPersonalityQuestionnaire     MusicPersonalityQuestionnaire?     @relation("musicPersonalityQuestionnaire")
  lifestylePreferencesQuestionnaire LifestylePreferencesQuestionnaire? @relation("lifestylePreferencesQuestionnaire")
  redFlagsQuestionnaire             RedFlagsQuestionnaire?             @relation("redFlagsQuestionnaire")
  dealBreakersQuestionnaire         DealBreakersQuestionnaire?         @relation("dealBreakersQuestionnaire")
  questionnaireCompletions          QuestionnaireCompletion[]          @relation("questionnaireCompletions")
  fraudAlerts                       FraudAlert[]
  redemptions                       Redemption[]
  premium                           UserPremium?
  reportsSubmitted                  Report[]                           @relation("reporter")
  reportsReceived                   Report[]                           @relation("reported")
  aiPicks                           AiPick[]                           @relation("aiPickUser")
  aiPickedFor                       AiPick[]                           @relation("aiPickProfile")
  thirdPartyRewards                 ThirdPartyReward[]
  adminProfile                      AdminProfile?
  callRequests                      CallRequest[]                      @relation("callRequester")
  callRequestsReceived              CallRequest[]                      @relation("callRecipient")
  callHistoryInitiated              CallHistory[]                      @relation("callHistoryCaller")
  callHistoryReceived               CallHistory[]                      @relation("callHistoryRecipient")
  adminRewards                      AdminReward[]                      @relation("adminRewards")
  receivedRewards                   AdminReward[]                      @relation("receivedRewards")
  undoActions                       UndoAction[]
  sponsorClicks                     SponsorClick[]
  referralsGiven                    Referral[]                         @relation("referrer")
  referralsReceived                 Referral[]                         @relation("referred")
  badges                            UserBadge[]
  typingIndicators                  TypingIndicator[]
  userBehaviors                     UserBehavior[]
  notifications                     Notification[]
  profileBoosts                     ProfileBoost[]
  personalityType                   String?
  profileScore                      Int?
  profileCompletion                 Int?
  preferences                       UserPreferences?
  discussionsCreated                Discussion[]                       @relation("DiscussionAuthor")
  discussionReplies                 DiscussionReply[]                  @relation("DiscussionReplyAuthor")
  eventsOrganized                   Event[]                            @relation("EventOrganizer")
  eventAttendances                  EventAttendee[]                    @relation("EventAttendee")
  messagesSent                      Int                                @default(0)
  messagesReceived                  Int                                @default(0)
  likesGiven                        Int                                @default(0)
  passesGiven                       Int                                @default(0)

  @@index([tier])
  @@index([country])
}

model UserPreferences {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  emailNotifications   Boolean  @default(true)
  pushNotifications    Boolean  @default(true)
  messageNotifications Boolean  @default(true)
  matchNotifications   Boolean  @default(true)
  likeNotifications    Boolean  @default(true)
  privateProfile       Boolean  @default(false)
  allowMessages        Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PointsTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  amount    Int
  type      String
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Ad {
  id           String   @id @default(cuid())
  title        String   @unique
  description  String?
  duration     Int
  rewardPoints Int
  videoUrl     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  views AdView[]

  @@index([isActive])
}

model AdView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  adId      String
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([completed])
}

model Survey {
  id           String   @id @default(cuid())
  title        String   @unique
  description  String?
  rewardPoints Int
  questions    String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  responses SurveyResponse[]

  @@index([isActive])
}

model SurveyResponse {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  surveyId  String
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers   String
  createdAt DateTime @default(now())

  @@unique([userId, surveyId])
  @@index([userId])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  sender     User      @relation("sender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  receiverId String
  receiver   User      @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  content    String
  photoUrl   String?
  pointsCost Int       @default(5)
  read       Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Like {
  id        String   @id @default(cuid())
  likerId   String
  liker     User     @relation("liker", fields: [likerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  likedId   String
  liked     User     @relation("liked", fields: [likedId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())

  @@unique([likerId, likedId])
  @@index([likerId])
  @@index([likedId])
}

model Match {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation("userMatches", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  matchedUserId     String
  matchedUser       User      @relation("matchedWithUser", fields: [matchedUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  dateOutcome       String?
  outcomeReportedAt DateTime?
  expiresAt         DateTime?
  isExpired         Boolean   @default(false)
  createdAt         DateTime  @default(now())

  @@unique([userId, matchedUserId])
  @@index([userId])
  @@index([matchedUserId])
  @@index([expiresAt])
  @@index([isExpired])
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  blockedId String
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Questionnaire {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PersonalityQuestionnaire {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation("personalityQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers     String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RelationshipGoalsQuestionnaire {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation("relationshipGoalsQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers     String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LifestyleQuestionnaire {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation("lifestyleQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers     String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ValuesBelifsQuestionnaire {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation("valuesBelifsQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers     String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InterestsHobbiesQuestionnaire {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation("interestsHobbiesQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers     String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MusicPersonalityQuestionnaire {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation("musicPersonalityQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers     String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LifestylePreferencesQuestionnaire {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation("lifestylePreferencesQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  answers     String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RedFlagsQuestionnaire {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation("redFlagsQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rawInput      String?
  selectedFlags String
  completedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DealBreakersQuestionnaire {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation("dealBreakersQuestionnaire", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rawInput         String?
  selectedBreakers String
  completedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model RedFlagsList {
  id           String   @id @default(cuid())
  flag         String   @unique
  frequency    Int      @default(0)
  topFourCount Int      @default(0)
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  isCustom     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([order])
  @@index([frequency])
  @@index([topFourCount])
}

model DealBreakersList {
  id           String   @id @default(cuid())
  breaker      String   @unique
  frequency    Int      @default(0)
  topFourCount Int      @default(0)
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([order])
  @@index([frequency])
  @@index([topFourCount])
}

model QuestionnaireCompletion {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("questionnaireCompletions", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type          String
  completed     Boolean   @default(false)
  completedAt   DateTime?
  coinsRewarded Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

model Reward {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  pointsCost  Int
  type        String
  duration    Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions Redemption[]

  @@index([isActive])
}

model Redemption {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rewardId    String
  reward      Reward    @relation(fields: [rewardId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pointsSpent Int
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

model UserPremium {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  unlimitedLikes    Boolean   @default(false)
  unlimitedMessages Boolean   @default(false)
  messagePriority   Boolean   @default(false)
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model FraudAlert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type        String
  severity    String   @default("low")
  description String
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([resolved])
  @@index([createdAt])
}

model Report {
  id               String   @id @default(cuid())
  reporterId       String
  reporter         User     @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reportedUserId   String
  reportedUser     User     @relation("reported", fields: [reportedUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type             String
  description      String
  status           String   @default("pending")
  action           String?
  reportedContent  String?
  reportedPhotoUrl String?
  createdAt        DateTime @default(now())

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@index([createdAt])
}

model AiPick {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("aiPickUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  profileId String
  profile   User     @relation("aiPickProfile", fields: [profileId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ThirdPartyReward {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  provider  String
  points    Int
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([provider])
  @@index([createdAt])
}

model AdminProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  phone      String?
  role       String   @default("moderator")
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([role])
}

model CallRequest {
  id          String    @id @default(cuid())
  callerId    String
  caller      User      @relation("callRequester", fields: [callerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipientId String
  recipient   User      @relation("callRecipient", fields: [recipientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  callType    String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  @@index([callerId])
  @@index([recipientId])
  @@index([status])
  @@index([createdAt])
}

model CallHistory {
  id          String    @id @default(cuid())
  callerId    String
  caller      User      @relation("callHistoryCaller", fields: [callerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipientId String
  recipient   User      @relation("callHistoryRecipient", fields: [recipientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  callType    String
  status      String
  duration    Int       @default(0)
  startedAt   DateTime
  endedAt     DateTime?
  createdAt   DateTime  @default(now())

  @@index([callerId])
  @@index([recipientId])
  @@index([status])
  @@index([startedAt])
}

model TickerMessage {
  id        String   @id @default(cuid())
  text      String
  action    String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

model AdminReward {
  id               String   @id @default(cuid())
  adminId          String
  admin            User     @relation("adminRewards", fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId           String?
  user             User?    @relation("receivedRewards", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  points           Int
  reason           String
  bulkDistribution Boolean  @default(false)
  recipientCount   Int      @default(1)
  notificationSent Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([adminId])
  @@index([userId])
  @@index([createdAt])
}

model UndoAction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actionType     String
  targetUserId   String
  pointsRefunded Int
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Sponsor {
  id        String   @id @default(cuid())
  name      String   @unique
  logo      String?
  website   String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clicks SponsorClick[]

  @@index([isActive])
  @@index([order])
}

model SponsorClick {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sponsorId String
  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sponsorId])
  @@index([createdAt])
}

model Referral {
  id                   String   @id @default(cuid())
  referrerId           String
  referrer             User     @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  referredId           String
  referred             User     @relation("referred", fields: [referredId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pointsAwarded        Int      @default(20)
  referredBonusAwarded Boolean  @default(false)
  referredBonusAmount  Int      @default(15)
  createdAt            DateTime @default(now())

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@index([createdAt])
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  badgeType   String
  name        String
  icon        String
  description String?
  awardedAt   DateTime @default(now())

  @@unique([userId, badgeType])
  @@index([userId])
  @@index([badgeType])
}

model TypingIndicator {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  conversationWith String
  isTyping         Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  @@unique([userId, conversationWith])
  @@index([userId])
}

model UserBehavior {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  targetUserId String
  actionType   String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([targetUserId])
  @@index([createdAt])
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type          String
  title         String
  message       String
  relatedUserId String?
  relatedId     String?
  read          Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([type])
}

model ProfileBoost {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  boostType            String    @default("standard")
  coinsCost            Int
  expiresAt            DateTime
  isActive             Boolean   @default(true)
  lastBoostAt          DateTime?
  nextBoostAvailableAt DateTime?
  createdAt            DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([isActive])
  @@index([createdAt])
}

model Discussion {
  id        String            @id @default(cuid())
  title     String
  content   String
  category  String            @default("general")
  authorId  String
  author    User              @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replies   DiscussionReply[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model DiscussionReply {
  id           String     @id @default(cuid())
  content      String
  authorId     String
  author       User       @relation("DiscussionReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Event {
  id           String          @id @default(cuid())
  title        String
  description  String?
  eventDate    DateTime
  location     String
  category     String          @default("general")
  organizerId  String
  organizer    User            @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  maxAttendees Int?
  attendees    EventAttendee[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([eventDate])
  @@index([category])
  @@index([organizerId])
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EventAttendee", fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("interested")
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}
